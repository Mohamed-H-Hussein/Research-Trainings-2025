// =============================
// Nextflow global configuration
// =============================
workDir = './work'                 // temporary working directory
timeline = 'reports/timeline.html'
report = 'reports/report.html'
trace = 'reports/trace.txt'
log = 'logs/nextflow.log'

// =============================
// Default process configuration
// =============================
process {
    executor = 'local'
    conda = 'envs/plant_wgs_env.yml'
    errorStrategy = 'retry'
    maxRetries = 2
}

// =============================
// Resource allocation per process
// =============================
process {
    withName: 'download_reference' {
        cpus = 2
        memory = '4 GB'
        time = '2h'
    }

    withName: 'index_reference' {
        cpus = 2
        memory = '8 GB'
        time = '2h'
    }

    withName: 'download_reads' {
        cpus = 2
        memory = '8 GB'
        time = '4h'
    }

    withName: 'qc_trimming' {
        cpus = 2
        memory = '8 GB'
        time = '2h'
    }

    withName: 'alignment' {
        cpus = 2
        memory = '12 GB'
        time = '8h'
    }

    withName: 'deduplication' {
        cpus = 2
        memory = '8 GB'
        time = '2h'
    }

    withName: 'variant_calling' {
        cpus = 2
        memory = '12 GB'
        time = '4h'
    }
}
